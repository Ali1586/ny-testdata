# .github/workflows/build-test.yml
name: Build and Test

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Hämta kod
        uses: actions/checkout@v3

      - name: Installera Python 3.9
        uses: actions/setup-python@v4
        with:
          python-version: "3.9"

      # Kör testfilen – testar alla GDPR-funktioner automatiskt
      - name: Kör tester (test_enkel.py)
        run: python test_enkel.py

      # Bygg Docker-imagen
      - name: Bygg Docker-image
        run: docker build -t gdpr-app .

      # Kör containern
      - name: Kör Docker-container
        run: docker run --rm gdpr-app